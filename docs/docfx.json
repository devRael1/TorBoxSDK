{
  "metadata": [
    {
      "src": [
        {
          "files": ["src/TorBoxSDK/TorBoxSDK.csproj"],
          "src": "../"
        }
      ],
      "dest": "api",
      "filter": "filterConfig.yml",
      "properties": {
        "TargetFramework": "net8.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": ["**/*.{md,yml}"],
        "exclude": ["_site/**", "filterConfig.yml"]
      }
    ],
    "resource": [
      {
        "files": ["**/images/**"]
      }
    ],
    "template": ["default", "modern", "templates/material"],
    "globalMetadata": {
      "_appTitle": "TorBoxSDK",
      "_appFooter": "Made by <a href='https://github.com/devRael1'>devRael1</a> with ❤️",
      "_appFaviconPath": "images/favicon.svg",
      "_enableSearch": true,
      "_gitContribute": {
        "repo": "https://github.com/devRael1/TorBoxSDK",
        "branch": "main",
        "apiSpecFolder": "docs/api"
      }
    },
    "postProcessors": ["ExtractSearchIndex"],
    "dest": "_site"
  }
}
